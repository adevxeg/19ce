<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_account_move_form" model="ir.ui.view">
            <field name="name">view.inherit.account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='button_cancel'][1]" position="attributes">
                    <attribute name="groups">
                        account_bulk_action.group_account_bulk_cancel,account_bulk_action.group_account_bulk_cancel_draft
                    </attribute>
                </xpath>
                <xpath expr="//button[@name='button_cancel'][2]" position="attributes">
                    <attribute name="groups">
                        account_bulk_action.group_account_bulk_cancel,account_bulk_action.group_account_bulk_cancel_draft
                    </attribute>
                </xpath>
                <xpath expr="//button[@name='button_draft']" position="attributes">
                    <attribute name="groups">
                        account_bulk_action.group_account_bulk_draft,account_bulk_action.group_account_bulk_cancel_draft
                    </attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>