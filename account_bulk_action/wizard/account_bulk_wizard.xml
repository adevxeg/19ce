<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_account_bulk_wizard_form" model="ir.ui.view">
            <field name="name">account.bulk.wizard.form</field>
            <field name="model">account.bulk.wizard</field>
            <field name="arch" type="xml">
                <form string="Bulk Confirmation">
                    <sheet>
                        <group>
                            <div class="alert alert-warning" role="alert">
                                You have selected
                                <field name="move_ids" widget="many2many_tags" readonly="1"/>
                                Are you want to
                                <field name="action_type"  class="oe_inline" readonly="1"/>
                            </div>
                        </group>
                        <footer>
                            <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                            <button string="Cancel" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_account_bulk_cancel_view" model="ir.actions.act_window">
            <field name="name">Bulk Cancel</field>
            <field name="res_model">account.bulk.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list,form</field>
            <field name="context">{'default_move_ids': active_ids, 'default_action_type': 'cancel'}</field>
            <field name="group_ids" eval="[
                (4, ref('base.group_system')),
                (4, ref('account_bulk_action.group_account_bulk_cancel')),
                (4, ref('account_bulk_action.group_account_bulk_cancel_draft')),
            ]"/>
        </record>
        <record id="action_account_bulk_draft_view" model="ir.actions.act_window">
            <field name="name">Bulk Set Draft</field>
            <field name="res_model">account.bulk.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list,form</field>
            <field name="context">{'default_move_ids': active_ids, 'default_action_type': 'draft'}</field>
            <field name="group_ids" eval="[
                (4, ref('base.group_system')),
                (4, ref('account_bulk_action.group_account_bulk_draft')),
                (4, ref('account_bulk_action.group_account_bulk_cancel_draft')),
            ]"/>
        </record>

    </data>
</odoo>