<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_account_move_form" model="ir.ui.view">
            <field name="name">view.inherit.account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="before">
                    <field name="product_variant_domain" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="before">
                    <field name="product_variant_domain" column_invisible="1"/>
                </xpath>
                 <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="attributes">
                    <attribute name="domain">product_variant_domain</attribute>
                </xpath>
                <xpath expr="//group[@id='header_right_group']" position="inside">
                    <label for="season_id"/>
                    <div name="season_div" class="d-flex">
                        <field name="season_id" readonly="context.get('active_id', False) or state != 'draft'"
                               options="{'no_create_edit':True, 'no_open':True, 'no_create':True}"/>
                    </div>
                </xpath>

            </field>
        </record>

    </data>
</odoo>