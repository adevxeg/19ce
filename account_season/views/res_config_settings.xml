<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_res_config_settings_form" model="ir.ui.view">
            <field name="name">view.inherit.res.config.settings.form</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="adevx_base.view_inherit_res_config_settings_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='accounting']" position="attributes">
                    <attribute name="invisible">0</attribute>
                </xpath>
                <xpath expr="//page[@name='accounting']//block[@id='accounting_general']" position="inside">
                    <setting help="Restrict bill refund lines season">
                        <field name="bill_refund_by_season"/>
                    </setting>
                </xpath>
            </field>
        </record>

    </data>
</odoo>