<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_account_move_form" model="ir.ui.view">
            <field name="name">view.inherit.account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_total']" position="before">
                    <field name="allow_reverse_calc" column_invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_total']" position="attributes">
                    <attribute name="readonly">not allow_reverse_calc</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>