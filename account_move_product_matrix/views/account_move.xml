<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_account_move_form" model="ir.ui.view">
            <field name="name">view.inherit.account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="before">
                    <field name="product_tmpl_domain" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="attributes">
                    <attribute name="column_invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="after">
                    <field name="parent_state" column_invisible="1"/>
                    <field name="product_tmpl_domain" column_invisible="1"/>
                    <field name="product_template_id"
                           string="Product"
                           readonly="parent_state != 'draft'"
                           domain="product_tmpl_domain"
                           widget="aml_product_many2one"/>
                    <field name="product_template_attribute_value_ids" column_invisible="1"/>
                    <field name="product_no_variant_attribute_value_ids" column_invisible="1"/>
                    <field name="is_configurable_product" column_invisible="1"/>
                </xpath>
                <field name="partner_id" position="after">
                    <field name="grid" invisible="1"/>
                    <field name="grid_product_tmpl_id" invisible="1"/>
                    <field name="grid_update" invisible="1"/>
                    <field name="report_grids" groups="base.group_no_one"/>
                </field>
            </field>
        </record>

    </data>
</odoo>
