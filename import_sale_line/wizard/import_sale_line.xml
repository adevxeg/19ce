<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_import_sale_line_form" model="ir.ui.view">
            <field name="name">view.import.sale.line.form</field>
            <field name="model">import.sale.line</field>
            <field name="arch" type="xml">
                <form string="Import Sale Line">
                    <sheet>
                        <group>
                            <group>
                                <field name="select_file" filename="file_name"/>
                                <field name="file_name" invisible="1"/>
                                <field name="order_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="import_by"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_import" string="Import" type="object" default_focus="1" class="oe_highlight"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_import_sale_line_view" model="ir.actions.act_window">
            <field name="name">Import Sale Line</field>
            <field name="res_model">import.sale.line</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>