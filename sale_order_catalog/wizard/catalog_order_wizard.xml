<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_catalog_order_wizard_form" model="ir.ui.view">
            <field name="name">catalog.order.wizard.view.form</field>
            <field name="model">catalog.order.wizard</field>
            <field name="arch" type="xml">
                <form string="Create Order" js_class="catalog_order_wizard_form">
                    <group>
                        <group>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <footer>
                        <button string="Create" class="btn-primary" special="save"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>