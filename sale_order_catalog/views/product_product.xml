<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_product_product_kanban" model="ir.ui.view">
            <field name="name">view.inherit.product.product.kanban</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="stock.product_view_kanban_catalog"/>
            <field name="arch" type="xml">
                <xpath expr="//kanban" position="attributes">
                    <attribute name="js_class">sale_kanban_catalog</attribute>
                </xpath>
            </field>
        </record>
        <record id="view_inherit_product_product_search" model="ir.ui.view">
            <field name="name">view.inherit.product.product.search</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_view_search_catalog"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <filter string="Quantity On Hand"
                            name="qty_available"
                            domain="[('qty_available', '>', 0)]"/>
                    <group>
                        <filter string="Product " name="group_by_product_tmpl_id"
                                context="{'group_by':'product_tmpl_id'}"/>
                    </group>
                </xpath>
            </field>
        </record>
        <record id="view_product_product_action" model="ir.actions.act_window">
            <field name="name">Catalog</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">kanban</field>
            <field name="view_id" ref="view_inherit_product_product_kanban"/>
            <field name="search_view_id" ref="product.product_view_search_catalog"/>
            <field name="context">
                {
                    'product_catalog_order_id': 0,
                    'product_catalog_order_model': 'sale.order',
                    'display_uom': 0,
                    'display_stock': 1,
                    'precision': 0,
                    'product_catalog_currency_id': 0,
                    'product_catalog_digits': 0,
                    'search_default_group_by_product_tmpl_id': 1
                }
            </field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first record
                </p>
            </field>
        </record>

    </data>
</odoo>