<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_account_payment_register_form" model="ir.ui.view">
            <field name="name">view.inherit.account.payment.register.form</field>
            <field name="model">account.payment.register</field>
            <field name="inherit_id" ref="account.view_account_payment_register_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_date']" position="after">
                    <field name="payment_method_code" invisible="1"/>
                    <field name="effective_date" invisible="payment_method_code not in ('pdc', 'check_printing')"/>
                    <field name="bank_reference" invisible="payment_method_code not in ('pdc', 'check_printing')"/>
                    <field name="cheque_reference" invisible="payment_method_code not in ('pdc', 'check_printing')"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>