<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_sale_order_form" model="ir.ui.view">
            <field name="name">view.inherit.sale.order.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']//list/field[@name='price_total']" position="after">
                    <field name="on_hand" optional="show"/>
                    <field name="free_qty" optional="show"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>