<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_res_config_settings_form" model="ir.ui.view">
            <field name="name">view.inherit.res.config.settings.form</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="adevx_base.view_inherit_res_config_settings_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='sales']" position="attributes">
                    <attribute name="invisible">0</attribute>
                </xpath>
                <xpath expr="//page[@name='sales']//block[@id='sales_general']" position="inside">
                    <setting help="Warehouse used by default when creating a sales order">
                        <field name="sale_warehouse_id" required="force_default_sale_warehouse"
                           options="{'no_open': True, 'no_create': True, 'no_create_edit': True}"/>
                        <setting invisible="not sale_warehouse_id" help="Force the default warehouse when creating a sales order">
                            <field name="force_default_sale_warehouse"/>
                        </setting>
                    </setting>
                </xpath>
                <xpath expr="//page[@name='sales']//block[@id='sales_general']" position="after">
                    <block title="Credit Note" id="sales_credit_note">
                        <setting help="Warehouse used by default when creating a credit note">
                            <field name="credit_note_warehouse_id" required="force_default_sale_warehouse"
                               options="{'no_open': True, 'no_create': True, 'no_create_edit': True}"/>
                            <setting invisible="not credit_note_warehouse_id" help="Force the default warehouse when creating a credit note">
                                <field name="force_default_sale_warehouse"/>
                            </setting>
                        </setting>
                        <setting help="Validate quantity sold when creating credit note">
                            <field name="credit_note_validate_qty_sold"/>
                        </setting>
                        <setting help="Restrict credit note lines by customer">
                            <field name="credit_note_by_customer"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>

    </data>
</odoo>