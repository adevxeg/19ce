<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_res_users_form" model="ir.ui.view">
            <field name="name">view.inherit.res.users.form</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="adevx_base.view_inherit_res_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='sales']" position="attributes">
                    <attribute name="invisible">0</attribute>
                </xpath>
                <xpath expr="//group[@name='sales']//group[@name='sales_right']" position="inside">
                    <field name="restrict_sale_warehouse_by_user"/>
                    <field name="allowed_warehouse_ids" widget="many2many_tags"
                           invisible="not restrict_sale_warehouse_by_user" required="restrict_sale_warehouse_by_user"
                           options="{'no_create_edit':True, 'no_open':True, 'no_create':True}"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>