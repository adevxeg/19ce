<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_sale_stock_form" model="ir.ui.view">
            <field name="name">view.inherit.sale,stock.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale_stock.view_order_form_inherit_sale_stock"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='delivery_count']" position="replace">
                    <field name="sales_type" invisible="1"/>
                    <field name="delivery_count" widget="statinfo" string="Delivery"
                           invisible="sales_type == 'credit_note'"/>
                    <field name="delivery_count" widget="statinfo" string="Receipt"
                           invisible="sales_type != 'credit_note'"/>
                </xpath>
            </field>
        </record>
        <record id="view_inherit_sale_order_form" model="ir.ui.view">
            <field name="name">view.inherit.sale.order.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="sales_type" invisible="1"/>
                    <field name="product_variant_domain" invisible="1"/>
                    <field name="product_tmpl_domain" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='partner_shipping_id']" position="after">
                    <field name="warehouse_id_domain" invisible="1"/>
                    <field name="warehouse_id" options="{'no_create': True}" force_save="1" readonly="state == 'sale'"/>
                </xpath>
                <xpath expr="//field[@name='invoice_count']" position="replace">
                    <field name="invoice_count" widget="statinfo" string="Invoices"
                           invisible="sales_type == 'credit_note'"/>
                    <field name="invoice_count" widget="statinfo" string="Credit Note"
                           invisible="sales_type != 'credit_note'"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="before">
                    <field name="product_variant_domain" column_invisible="1"/>
                    <field name="product_tmpl_domain" column_invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                    <attribute name="domain">product_variant_domain</attribute>
                </xpath>
                <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="attributes">
                    <attribute name="domain">product_tmpl_domain</attribute>
                </xpath>
                <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="after">
                    <field name="qty_sold" column_invisible="parent.sales_type != 'credit_note'" optional="show"/>
                </xpath>
            </field>
        </record>
        <record id="action_sales_credit_note" model="ir.actions.act_window">
            <field name="name">Sales Credit Note</field>
            <field name="res_model">sale.order</field>
            <field name="view_id" ref="sale.view_order_tree"/>
            <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
            <field name="search_view_id" ref="sale.sale_order_view_search_inherit_sale"/>
            <field name="domain">[('sales_type', '=', 'credit_note')]</field>
            <field name="context">{'default_sales_type': 'credit_note'}</field>
        </record>
        <record id="sale.action_quotations_with_onboarding" model="ir.actions.act_window">
            <field name="domain">[('sales_type', '=', 'sales')]</field>
        </record>
        <record id="sale.action_orders" model="ir.actions.act_window">
            <field name="domain">[('state', 'not in', ('draft', 'sent', 'cancel')), ('sales_type', '=', 'sales')]
            </field>
        </record>
        <menuitem id="menu_sales_credit_note"
                  name="Credit Notes"
                  parent="sale.sale_order_menu"
                  action="action_sales_credit_note"
                  sequence="90"/>

    </data>
</odoo>