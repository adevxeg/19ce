<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_sale_order_form" model="ir.ui.view">
            <field name="name">view.inherit.sale.order.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale_margin.sale_margin_sale_order"/>
            <field name="arch" type="xml">
                <xpath expr="//div[1]" position="attributes">
                    <attribute name="groups">so_margin.group_sale_margin</attribute>
                </xpath>
                <xpath expr="//field[@name='order_line']//form//field[@name='purchase_price']" position="attributes">
                    <attribute name="groups">product_base.group_product_cost</attribute>
                </xpath>
                <xpath expr="//field[@name='order_line']//list//field[@name='purchase_price']" position="attributes">
                    <attribute name="groups">product_base.group_product_cost</attribute>
                </xpath>
                <xpath expr="//field[@name='order_line']//list//field[@name='margin']" position="attributes">
                    <attribute name="groups">so_margin.group_sale_margin</attribute>
                </xpath>
                <xpath expr="//field[@name='order_line']//list//field[@name='margin_percent']" position="attributes">
                    <attribute name="groups">so_margin.group_sale_margin</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>