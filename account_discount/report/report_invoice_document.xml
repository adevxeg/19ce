<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <template id="inherit_report_invoice_document" inherit_id="account.report_invoice_document">
            <xpath expr="//t[@t-call='account.document_tax_totals']" position="before">
                <tr class="border-black o_total" t-if="o.total_discount">
                    <td>
                        <strong>Total Discount</strong>
                    </td>
                    <td class="text-end">
                        <span t-field="o.total_discount"/>
                    </td>
                </tr>
            </xpath>
        </template>

    </data>
</odoo>
