<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_account_move_form" model="ir.ui.view">
            <field name="name">view.inherit.account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="account_discount_type" invisible="1"/>
                </xpath>
                <xpath expr="//group[hasclass('oe_invoice_lines_tab')]" position="before">
                    <div class="justify-content-end d-flex d-print-none gap-1 mb-2 col-12"
                         name="am_button_below_order_lines">
                        <button
                            name="action_open_discount_wizard"
                            type="object"
                            class="btn btn-secondary"
                            invisible="state != 'draft'">
                            Discount
                            <span invisible="account_discount_type != 'adevx'">
                                (<field name="total_discount"/>)
                            </span>
                        </button>
                    </div>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']//list/field[@name='discount']" position="attributes">
                    <attribute name="digits">[16, 2]</attribute>
                    <attribute name="readonly">parent.account_discount_type != 'standard'</attribute>
                    <attribute name="force_save">1</attribute>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']//list/field[@name='discount']" position="after">
                    <field name='amount_discount' optional="hide"
                           column_invisible="parent.account_discount_type != 'adevx'"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
