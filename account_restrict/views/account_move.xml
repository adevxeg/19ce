<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_account_move_form" model="ir.ui.view">
            <field name="name">view.inherit.account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_shipping_id']" position="before">
                    <field name="move_type" invisible="1"/>
                    <field name="partner_balance_before"
                           invisible="move_type not in ['out_invoice', 'out_refund']"/>
                    <field name="partner_balance"
                           invisible="move_type not in ['out_invoice', 'out_refund']"/>
                </xpath>
                <xpath expr="//field[@name='invoice_date']" position="after">
                    <field name="restrict_update_line_qty" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='quantity']" position="attributes">
                    <attribute name="readonly">parent.restrict_update_line_qty</attribute>
                </xpath>
                <xpath expr="//sheet" position="before">
                    <field name="allow_cancel_entry" invisible="1"/>
                </xpath>
                <xpath expr="//button[@name='button_cancel'][2]" position="attributes">
                    <attribute name="invisible">not id or state != 'draft' or not allow_cancel_entry</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reverse']" position="attributes">
                    <attribute name="groups">account_restrict.group_show_credit_note_refund</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="before">
                    <field name="product_variant_domain" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="before">
                    <field name="product_variant_domain" column_invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="attributes">
                    <attribute name="domain">product_variant_domain</attribute>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_total']" position="after">
                    <field name="sold_qty" optional="show" column_invisible="parent.move_type != 'out_refund'"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>