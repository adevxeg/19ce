<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_cash_in_out_form" model="ir.ui.view">
            <field name="name">view.cash.in.out.form</field>
            <field name="model">cash.in.out</field>
            <field name="arch" type="xml">
                <form string="">
                    <sheet>
                        <group>
                            <group>
                                <field name="amount"/>
                            </group>
                            <group>
                                <field name="account_id"/>
                                <field name="sale_cash_in_out_journal_id" invisible="not account_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Reason">
                                <field name="reason" placeholder="Cash in/out reason ..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_cash_in" string="Cash In" type="object" class="btn btn-success"/>
                        <button name="action_cash_out" string="Cash Out" type="object" class="btn btn-danger"/>
                        <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_cash_in_out_view" model="ir.actions.act_window">
            <field name="name">Cash In/Out</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cash.in.out</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
        <menuitem id="menu_cash_in_out_view"
                  name="Cash In/Out"
                  parent="sale.sale_menu_root"
                  action="action_cash_in_out_view"
                  sequence="40"/>

    </data>
</odoo>