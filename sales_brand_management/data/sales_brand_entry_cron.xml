<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="cron_sales_brand_entry" forcecreate="True" model="ir.cron">
            <field name="name">Sales Brand Entry</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model.generate_sales_brand_entry()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>
        <record id="cron_sales_rent_entry" forcecreate="True" model="ir.cron">
            <field name="name">Sales Rent Entry</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model.generate_sales_rent_entry()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>

    </data>
</odoo>