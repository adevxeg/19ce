<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_inherit_res_config_settings_form" model="ir.ui.view">
            <field name="name">view.inherit.res.config.settings.form</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="adevx_base.view_inherit_res_config_settings_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='sales']" position="attributes">
                    <attribute name="invisible">0</attribute>
                </xpath>
                <xpath expr="//page[@name='sales']" position="inside">
                    <block title="Sales Brand Configuration"
                           groups="sales_brand_management.group_sales_brand_management">
                        <setting>
                            <field name="allow_sales_brand_entry"/>
                        </setting>
                        <setting invisible="not allow_sales_brand_entry">
                            <field name="sales_brand_warehouse_restrict"/>
                        </setting>
                        <setting invisible="not allow_sales_brand_entry">
                            <field name="sales_warehouse_categ_restrict"/>
                        </setting>
                        <notebook invisible="not allow_sales_brand_entry">
                            <page string="Brand Configuration">
                                <block>
                                    <setting>
                                        <div class="content-group">
                                            <label for="sales_brand_entry_days"/>
                                        </div>
                                        <div class="content-group">
                                            <field name="sales_brand_entry_days" required="allow_sales_brand_entry"/>
                                        </div>
                                    </setting>
                                    <setting class="col-12 col-lg-12 o_setting_box">
                                        <field name="sales_brand_ids" required="allow_sales_brand_entry">
                                            <list editable="bottom">
                                                <field name="name"/>
                                                <field name="type"/>
                                                <field name="journal_id"/>
                                                <field name="debit_account_id"/>
                                                <field name="credit_account_id"/>
                                                <field name="tax_id" required="type == 'tax'" readonly="type != 'tax'"/>
                                            </list>
                                        </field>
                                    </setting>
                                </block>
                            </page>
                            <page string="Rent Configuration">
                                <block>
                                    <setting string="Rent Entry">
                                        <div class="content-group">
                                            <label for="sales_rent_journal_id"/>
                                        </div>
                                        <div class="content-group">
                                            <field name="sales_rent_journal_id"
                                                   required="allow_sales_brand_entry"/>
                                        </div>
                                        <div class="content-group">
                                            <label for="sales_rent_debit_account_id"/>
                                        </div>
                                        <div class="content-group">
                                            <field name="sales_rent_debit_account_id"
                                                   required="allow_sales_brand_entry"/>
                                        </div>
                                        <div class="content-group">
                                            <label for="sales_rent_credit_account_id"/>
                                        </div>
                                        <div class="content-group">
                                            <field name="sales_rent_credit_account_id"
                                                   required="allow_sales_brand_entry"/>
                                        </div>
                                        <div class="content-group">
                                            <label for="sales_rent_entry_days"/>
                                        </div>
                                        <div class="content-group">
                                            <field name="sales_rent_entry_days"
                                                   required="allow_sales_brand_entry"/>
                                        </div>
                                    </setting>
                                </block>
                            </page>
                        </notebook>
                    </block>
                </xpath>
            </field>
        </record>

    </data>
</odoo>