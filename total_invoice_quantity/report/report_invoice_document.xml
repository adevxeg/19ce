<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <template id="inherit_report_invoice_document" inherit_id="account.report_invoice_document">
            <xpath expr="//div[@id='informations']" position="inside">
                <div class="col" t-if="o.user_id" name="sale_person">
                    <strong>Sales Person:</strong>
                    <br/>
                    <span t-field="o.user_id"/>
                </div>
            </xpath>
            <xpath expr="//t[@t-call='account.document_tax_totals']" position="before">
                <tr class="border-black o_total">
                    <td>
                        <strong>Total Products</strong>
                    </td>
                    <td class="text-end">
                        <span t-field="o.total_product"/>
                    </td>
                </tr>
                <tr class="border-black o_total">
                    <td>
                        <strong>Total Quantity</strong>
                    </td>
                    <td class="text-end">
                        <span t-field="o.total_quantity"/>
                    </td>
                </tr>
            </xpath>
        </template>

    </data>
</odoo>
